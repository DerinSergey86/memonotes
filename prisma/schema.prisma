generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String
  tags      String   // JSON-строка с массивом тегов
  type      String   @default("note") // "note" или "task"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // Поля для задач (опциональные)
  dueDate   DateTime? // срок выполнения
  completed Boolean   @default(false)
  latitude  Float?    // координаты
  longitude Float?
  location  String?   // человекочитаемый адрес
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // пока храним пароль в открытом виде (небезопасно), позже добавим хеширование
  notes     Note[]
}